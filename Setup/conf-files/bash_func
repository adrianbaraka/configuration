# bash prompt
setPrompt() {
    local exitCode=$?
    local space branch
    
    PS1=""
    space=""

    if ((exitCode != 0)); then
        PS1+='\[\e[91m\]вЏє\[\e[0m\]'
        # add a space in the bottom to compensate for this
        space=" "
    fi

    PS1+="\[\e[92;1m\]в”Њв”Ђв”Ђ"

    # Include the virtual environment name if it exists
    if [[ -n "$VIRTUAL_ENV" ]]; then
        envName="${VIRTUAL_ENV##*/}"
        #echo "$envName"
        PS1+="\[\e[97m\](\[\e[94m\]${envName}\[\e[97m\]) "
    fi

    # show the hostname if remote
    if [[ -n "$IS_REMOTE" ]]; then
        PS1+="(\[\e[92;1;3m\]\u\[\e[0;92m\]@\[\e[2m\]\H\[\e[0m\])\[\e[1m\]-[\[\e[38;5;38;3m\]\w\[\e[23;97m\]]\[\e[0m\] "
    else
        PS1+="(\[\e[92;1;3m\]\u\[\e[0m\])\[\e[1m\]-[\[\e[38;5;38;3m\]\w\[\e[23;97m\]]\[\e[0m\]"
    fi

    # Include git branch if a git repo
    branch=$(git branch --show-current 2>/dev/null)
    if [[ -n "$branch" ]]; then
        PS1+="(\[\e[93m\]${branch}\[\e[0m\])"
    fi

    PS1+="\n${space}\[\e[92;1m\]в””в”Ђ\[\e[0m\]рџ‘Ђ\[\e[38;5;202;1m\] \[\e[0m\]"
}
PROMPT_COMMAND=setPrompt


