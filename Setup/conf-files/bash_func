# functions

cdl() {
    if (($# == 0)); then
        echo "Usage: cdl <directory>"
        return 1
    fi

    cd "$1" || return 1
    ls
}

#Update and upgrade packages
update(){
    sudo apt update
    sudo apt upgrade
}

